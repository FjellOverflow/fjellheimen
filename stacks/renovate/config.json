{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "platform": "github",
  "onboarding": false,
  "requireConfig": "optional",
  "dependencyDashboard": true,
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "reportType": "file",
  "reportPath": "/report/report.json",
  "rangeStrategy": "bump",
  "minimumReleaseAge": "1 day",
  "packageRules": [
    { "matchPackageNames": ["*"], "groupName": "all dependencies", "groupSlug": "all-deps" },
    { "matchUpdateTypes": ["major"], "groupName": null }
  ]
}
